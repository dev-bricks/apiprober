{
    "delay_ms": 500,
    "max_requests": 500,
    "max_depth": 3,
    "timeout_seconds": 30,
    "connect_timeout_s": 10,
    "read_timeout_s": 30,
    "max_retries": 2,
    "user_agent": "ApiProber/0.1 (github.com/dev-bricks/apiprober; passive-discovery)",
    "respect_robots_txt": true,
    "skip_destructive": true,
    "strategies": ["openapi", "wordlist", "pattern", "response_driven"],
    "auth": {
        "type": "none",
        "value": ""
    }
}
